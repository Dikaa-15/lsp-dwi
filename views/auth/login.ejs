<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://unpkg.com/lucide@latest"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: { sans: ['Inter', 'sans-serif'] },
          colors: {
            brand: {
              red: '#EF4444',
              'red-hover': '#DC2626',
              'red-light': '#FEF2F2',
              dark: '#1E293B',
            }
          }
        }
      }
    }
  </script>
  <style>
    * { -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
    body { font-feature-settings: "cv11", "ss01"; }
    .input-field { transition: box-shadow 0.2s ease, border-color 0.2s ease; }
    .input-field:focus-within { box-shadow: 0 0 0 2px rgba(239,68,68,0.25); border-color: #EF4444; }
    .login-image { filter: saturate(0.25) brightness(0.92); transition: filter 0.6s ease; }
    .login-image:hover { filter: saturate(0.4) brightness(0.95); }
    .link-anim { position: relative; }
    .link-anim::after { content: ''; position: absolute; left: 0; bottom: -1px; width: 0; height: 1px; background: #EF4444; transition: width 0.25s ease; }
    .link-anim:hover::after { width: 100%; }
  </style>
</head>
<body class="bg-white font-sans text-brand-dark min-h-screen">

  <div class="min-h-screen flex">
    <!-- ====== LEFT: Image Panel ====== -->
    <div class="hidden lg:flex lg:w-[45%] xl:w-[48%] bg-slate-50 relative overflow-hidden">
      <img
        src="https://picsum.photos/seed/garage-engine-aesthetic/1200/1600.jpg"
        alt="Modern car engine"
        class="login-image absolute inset-0 w-full h-full object-cover"
      >
    </div>

    <!-- ====== RIGHT: Login Form ====== -->
    <div class="flex-1 flex items-center justify-center px-4 sm:px-6 lg:px-10 xl:px-16 py-8">
      <div class="w-full max-w-[400px]">

        <!-- Logo -->
        <div class="flex items-center gap-2 mb-10">
          <div class="w-8 h-8 bg-brand-red rounded-md flex items-center justify-center">
            <i data-lucide="cog" class="w-4 h-4 text-white"></i>
          </div>
          <span class="text-lg font-semibold text-brand-dark tracking-tight">AutoPart<span class="text-brand-red">Center</span></span>
        </div>

        <div class="mb-8">
          <h1 class="text-2xl font-bold text-brand-dark tracking-tight leading-tight">Selamat Datang Kembali</h1>
          <p class="mt-2 text-sm text-slate-500 leading-relaxed">Masuk ke akun Anda untuk melanjutkan belanja suku cadang.</p>
        </div>

        <% if (messages.error) { %>
            <div class="mb-6 p-4 bg-red-50 border border-red-100 text-red-600 text-sm rounded-md flex items-center gap-3">
                <i data-lucide="alert-circle" class="w-4 h-4"></i>
                <span><%= messages.error %></span>
            </div>
        <% } %>
        <% if (messages.success) { %>
            <div class="mb-6 p-4 bg-green-50 border border-green-100 text-green-600 text-sm rounded-md flex items-center gap-3">
                <i data-lucide="check-circle" class="w-4 h-4"></i>
                <span><%= messages.success %></span>
            </div>
        <% } %>

        <form action="/auth/login" method="POST" class="space-y-5">
          <div>
            <label for="email" class="block text-sm font-medium text-brand-dark mb-1.5">Email</label>
            <div class="input-field flex items-center border border-slate-200 rounded-md bg-white h-11 px-3">
              <i data-lucide="user" class="w-4 h-4 text-slate-400 shrink-0"></i>
              <input name="email" id="email" type="email" placeholder="nama@email.com" class="flex-1 bg-transparent text-sm text-brand-dark placeholder-slate-400 ml-3 outline-none" required>
            </div>
          </div>

          <div>
            <label for="password" class="block text-sm font-medium text-brand-dark mb-1.5">Password</label>
            <div class="input-field flex items-center border border-slate-200 rounded-md bg-white h-11 px-3">
              <i data-lucide="lock" class="w-4 h-4 text-slate-400 shrink-0"></i>
              <input name="password" id="password" type="password" placeholder="Masukkan password" class="flex-1 bg-transparent text-sm text-brand-dark placeholder-slate-400 ml-3 outline-none" required>
            </div>
          </div>

          <button type="submit" class="w-full h-11 flex items-center justify-center bg-brand-red hover:bg-brand-red-hover text-white text-sm font-semibold rounded-md transition-colors duration-200">
            Masuk
          </button>
        </form>

        <p class="text-center text-sm text-slate-500 mt-8">
          Belum punya akun?
          <a href="/auth/register" class="link-anim font-semibold text-brand-red hover:text-brand-red-hover transition-colors ml-0.5">Daftar sekarang</a>
        </p>

        <div class="flex justify-center mt-6">
          <a href="javascript:history.back()" class="inline-flex items-center gap-1.5 text-xs font-semibold text-slate-400 hover:text-brand-red transition-colors border border-slate-200 px-4 py-2 rounded-full hover:border-brand-red">
            <i data-lucide="arrow-left" class="w-3 h-3"></i>
            Kembali
          </a>
        </div>

      </div>
    </div>
  </div>

  <script>
    lucide.createIcons();
  </script>
</body>
</html>
