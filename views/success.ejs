<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <script src="https://unpkg.com/lucide@latest"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: { sans: ['Inter', 'sans-serif'] },
          colors: {
            brand: {
              red: '#EF4444',
              'red-hover': '#DC2626',
              dark: '#1E293B',
            }
          }
        }
      }
    }
  </script>
  <style>
    * { -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
    body { font-feature-settings: "cv11", "ss01"; }
    .success-icon { animation: successPop 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards; }
    @keyframes successPop { from { opacity: 0; transform: scale(0.5); } to { opacity: 1; transform: scale(1); } }
  </style>
</head>
<body class="bg-white font-sans text-brand-dark min-h-screen flex flex-col">

  <header class="w-full py-5 px-4 sm:px-6">
    <div class="max-w-7xl mx-auto">
      <a href="/" class="flex items-center gap-2">
        <div class="w-7 h-7 bg-brand-red rounded-md flex items-center justify-center">
          <i data-lucide="cog" class="w-3.5 h-3.5 text-white"></i>
        </div>
        <span class="text-sm font-semibold text-brand-dark">AutoPart<span class="text-brand-red">Center</span></span>
      </a>
    </div>
  </header>

  <main class="flex-1 flex items-center justify-center px-4 py-8">
    <div class="w-full max-w-md bg-white rounded-lg border border-slate-100 shadow-sm p-8 sm:p-10 text-center">
        
        <div class="flex justify-center mb-8">
            <div class="success-icon w-20 h-20 bg-green-500 rounded-full flex items-center justify-center shadow-lg shadow-green-200">
                <i data-lucide="check" class="w-10 h-10 text-white"></i>
            </div>
        </div>

        <h1 class="text-2xl font-bold text-brand-dark mb-4">Pesanan Berhasil!</h1>
        <p class="text-sm text-slate-500 leading-relaxed mb-8">
            Terima kasih! Pesanan Anda telah kami terima dan sedang menunggu verifikasi pembayaran oleh Admin.
        </p>

        <div class="bg-slate-50 rounded-lg py-4 mb-8">
            <p class="text-[10px] text-slate-400 uppercase font-bold mb-1">ID Pesanan</p>
            <p class="text-lg font-mono font-bold text-brand-dark"><%= id_pembelian %></p>
        </div>

        <div class="space-y-3">
            <a href="/users/pesanan" class="block w-full h-12 flex items-center justify-center bg-brand-red hover:bg-brand-red-hover text-white text-sm font-semibold rounded-lg transition-all">
                Lacak Pesanan Saya
            </a>
            <a href="/" class="block w-full h-12 flex items-center justify-center border-2 border-slate-200 text-slate-500 hover:text-brand-red hover:border-brand-red text-sm font-semibold rounded-lg transition-all">
                Kembali ke Beranda
            </a>
            <%- include('partials/back-button', { fallback: '/', wrapperClass: 'pt-2 flex justify-center' }) %>
        </div>
    </div>
  </main>

  <footer class="py-5 text-center">
    <p class="text-[11px] text-slate-300">&copy; 2026 AutoPart Center. All rights reserved.</p>
  </footer>

  <script>
    lucide.createIcons();
  </script>
</body>
</html>
