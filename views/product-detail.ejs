<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <script src="https://unpkg.com/lucide@latest"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: { sans: ['Inter', 'sans-serif'] },
          colors: {
            brand: {
              red: '#EF4444',
              'red-hover': '#DC2626',
              'red-light': '#FEF2F2',
              dark: '#1E293B',
            }
          }
        }
      }
    }
  </script>
  <style>
    * { -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
    body { font-feature-settings: "cv11", "ss01"; }
    .qty-btn:hover { background-color: #F1F5F9; color: #1E293B; }
    .tab-btn { position: relative; transition: color 0.2s ease; }
    .tab-btn.active { color: #1E293B; font-weight: 600; }
    .tab-btn.active::after { content: ''; position: absolute; left: 0; bottom: -1px; width: 100%; height: 2px; background: #EF4444; border-radius: 1px; }
    .cart-badge-pop { animation: cartBadgePop 0.45s cubic-bezier(0.34, 1.56, 0.64, 1); }
    .cart-link-pop { animation: cartLinkPop 0.45s cubic-bezier(0.34, 1.56, 0.64, 1); }
    @keyframes cartBadgePop {
      0% { transform: scale(0.7); }
      55% { transform: scale(1.35); }
      100% { transform: scale(1); }
    }
    @keyframes cartLinkPop {
      0% { transform: scale(1); }
      45% { transform: scale(1.08); }
      100% { transform: scale(1); }
    }
  </style>
</head>
<body class="bg-white font-sans text-brand-dark">

  <div id="toast-container" class="fixed top-20 right-4 z-[200] flex flex-col gap-2 items-end pointer-events-none"></div>

  <!-- HEADER -->
  <header class="sticky top-0 z-50 bg-white/95 backdrop-blur-md border-b border-slate-100 shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-14 flex items-center">
      <a href="/" class="flex items-center gap-2">
        <div class="w-7 h-7 bg-brand-red rounded-md flex items-center justify-center">
          <i data-lucide="cog" class="w-3.5 h-3.5 text-white"></i>
        </div>
        <span class="text-sm font-semibold text-brand-dark hidden sm:block">AutoPart<span class="text-brand-red">Center</span></span>
      </a>
      <div class="ml-auto flex items-center gap-4">
        <% if (locals.user) { %>
            <a href="/users/pesanan" class="relative w-10 h-10 flex items-center justify-center rounded-md hover:bg-slate-50 text-slate-600" title="Lacak Pesanan">
                <i data-lucide="clipboard-list" class="w-5 h-5"></i>
                <% if (activeOrdersCount > 0) { %>
                    <span class="absolute -top-1 -right-1 w-5 h-5 bg-brand-red text-white text-[10px] font-bold rounded-full flex items-center justify-center border-2 border-white transition-all">
                        <%= activeOrdersCount %>
                    </span>
                <% } %>
            </a>
            <a href="/users/profile" class="w-10 h-10 flex items-center justify-center rounded-md hover:bg-slate-50 text-slate-600" title="Profil">
                <i data-lucide="user" class="w-5 h-5"></i>
            </a>
            <a id="cart-link" href="/cart" class="relative w-10 h-10 flex items-center justify-center rounded-md hover:bg-slate-50 text-slate-600" title="Keranjang">
                <i data-lucide="shopping-cart" class="w-5 h-5"></i>
                <span id="cart-badge" class="absolute -top-1 -right-1 w-5 h-5 bg-brand-red text-white text-[10px] font-bold rounded-full flex items-center justify-center border-2 border-white transition-all <%= cartCount > 0 ? 'scale-100' : 'scale-0' %>">
                    <%= cartCount %>
                </span>
            </a>
            <a href="/auth/logout" class="text-xs font-semibold text-slate-500 hover:text-brand-red">Logout</a>
        <% } else { %>
            <a href="/auth/login" class="text-xs font-semibold text-slate-500 hover:text-brand-red">Masuk</a>
        <% } %>
      </div>
    </div>
  </header>

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="mb-8">
      <%- include('partials/back-button', { fallback: '/', wrapperClass: '' }) %>
    </div>

    <div class="grid lg:grid-cols-2 gap-12">
      <!-- LEFT: IMAGE -->
      <div class="bg-slate-50 rounded-xl aspect-square flex items-center justify-center p-12 border border-slate-100">
        <img src="<%= product.gambar || '/images/default-produk.png' %>" alt="<%= product.nama_produk %>" class="w-full h-full object-contain mix-blend-multiply">
      </div>

      <!-- RIGHT: INFO -->
      <div>
        <div class="mb-4">
          <span class="inline-flex items-center text-xs text-slate-500 bg-slate-100 px-2.5 py-1 rounded-md">
            <%= product.nama_kategori %>
          </span>
        </div>

        <h1 class="text-3xl font-bold text-brand-dark leading-tight mb-2"><%= product.nama_produk %></h1>
        <p class="text-sm text-slate-400 mb-6">Brand: <span class="font-medium text-slate-600"><%= product.nama_brand %></span></p>

        <div class="flex items-center justify-between mb-8">
          <div>
            <p class="text-3xl font-bold text-brand-red">Rp<%= product.harga.toLocaleString('id-ID') %></p>
          </div>
          <div class="bg-green-50 px-3 py-1.5 rounded-md">
            <span class="text-xs font-medium text-green-700">Stok: <strong><%= product.stok %> Unit</strong></span>
          </div>
        </div>

        <div class="h-px bg-slate-100 mb-8"></div>

        <!-- ACTIONS -->
        <div class="space-y-6">
          <div class="flex items-center gap-4">
            <div class="flex items-center border border-slate-200 rounded-md">
              <button onclick="changeQty(-1)" class="w-10 h-10 flex items-center justify-center text-slate-400"><i data-lucide="minus" class="w-4 h-4"></i></button>
              <span id="qty-display" class="w-12 h-10 flex items-center justify-center text-sm font-semibold border-x border-slate-200">1</span>
              <button onclick="changeQty(1)" class="w-10 h-10 flex items-center justify-center text-slate-400"><i data-lucide="plus" class="w-4 h-4"></i></button>
            </div>
            <button onclick="addToCart()" class="flex-1 h-12 flex items-center justify-center gap-2 bg-brand-red hover:bg-brand-red-hover text-white text-sm font-semibold rounded-md transition-all">
              <i data-lucide="shopping-cart" class="w-4 h-4"></i>
              Tambah ke Keranjang
            </button>
          </div>
        </div>

        <!-- DESCRIPTION -->
        <div class="mt-12">
            <h3 class="text-sm font-bold uppercase tracking-wider text-slate-400 mb-4">Deskripsi Produk</h3>
            <p class="text-sm text-slate-600 leading-relaxed"><%= product.deskripsi || 'Tidak ada deskripsi.' %></p>
        </div>
      </div>
    </div>

    <!-- RELATED -->
    <% if (related.length > 0) { %>
        <section class="mt-20">
            <h2 class="text-xl font-bold text-brand-dark mb-8">Produk Serupa</h2>
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-6">
                <% related.forEach(p => { %>
                    <a href="/produk/<%= p.kode_produk %>" class="group bg-white rounded-md border border-slate-100 overflow-hidden hover:shadow-md transition-all">
                        <div class="aspect-square bg-slate-50 p-4">
                            <img src="<%= p.gambar || '/images/default-produk.png' %>" alt="" class="w-full h-full object-contain mix-blend-multiply group-hover:scale-105 transition-transform">
                        </div>
                        <div class="p-4">
                            <p class="text-xs text-brand-dark font-medium line-clamp-2 mb-2"><%= p.nama_produk %></p>
                            <p class="text-sm font-bold text-brand-red">Rp<%= p.harga.toLocaleString('id-ID') %></p>
                        </div>
                    </a>
                <% }) %>
            </div>
        </section>
    <% } %>
  </main>

  <script>
    let qty = 1;
    const maxStok = <%= product.stok %>;
    const kodeProduk = '<%= product.kode_produk %>';

    function changeQty(delta) {
        qty = Math.max(1, Math.min(maxStok, qty + delta));
        document.getElementById('qty-display').textContent = qty;
    }

    function addToCart() {
        if (!'<%= locals.user %>') {
            window.location.href = '/auth/login';
            return;
        }

        fetch('/cart/add', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ kode_produk: kodeProduk, jumlah: qty })
        }).then(res => res.json()).then(data => {
            if (data.success) {
                updateCartBadge(data.cartCount, data.addedNewItem);
                showToast(data.message, 'success');
            } else {
                showToast(data.message, 'error');
            }
        });
    }

    function updateCartBadge(nextCount, shouldAnimate = false) {
        const badge = document.getElementById('cart-badge');
        const cartLink = document.getElementById('cart-link');

        if (!badge || typeof nextCount !== 'number') return;

        badge.textContent = nextCount;
        badge.classList.toggle('scale-0', nextCount === 0);
        badge.classList.toggle('scale-100', nextCount > 0);
        window.AutopartCartBadge?.set(nextCount);

        if (shouldAnimate && nextCount > 0) {
            badge.classList.remove('cart-badge-pop');
            cartLink?.classList.remove('cart-link-pop');

            void badge.offsetWidth;

            badge.classList.add('cart-badge-pop');
            cartLink?.classList.add('cart-link-pop');

            window.setTimeout(() => {
                badge.classList.remove('cart-badge-pop');
                cartLink?.classList.remove('cart-link-pop');
            }, 500);
        }
    }

    function showToast(message, type = 'info') {
        const container = document.getElementById('toast-container');
        const toast = document.createElement('div');
        const bg = type === 'success' ? 'bg-green-500' : 'bg-red-500';
        toast.className = `px-6 py-3 ${bg} text-white text-sm font-medium rounded-md shadow-lg animate-bounce`;
        toast.textContent = message;
        container.appendChild(toast);
        setTimeout(() => toast.remove(), 3000);
    }

    lucide.createIcons();
  </script>
  <%- include('partials/cart-badge-sync') %>
</body>
</html>
