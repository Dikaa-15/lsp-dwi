<%- include('partials/header') %>
<%- include('partials/sidebar') %>

<div class="mb-6">
  <h1 class="text-xl font-bold text-brand-dark tracking-tight">Selamat Datang, Admin</h1>
  <p class="text-xs text-slate-400 mt-0.5">Ringkasan operasional hari ini.</p>
</div>

<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
  <div class="stat-card bg-white rounded-xl border border-slate-200 p-5 shadow-sm">
    <div class="flex items-center justify-between mb-3">
        <div class="w-8 h-8 bg-blue-50 rounded-lg flex items-center justify-center">
            <i data-lucide="trending-up" class="w-4 h-4 text-blue-500"></i>
        </div>
    </div>
    <p class="text-2xl font-bold text-slate-900 tabular-nums"><%= stats.totalPenjualan %></p>
    <p class="text-[11px] text-slate-400 mt-0.5">Total Penjualan</p>
  </div>
  
  <div class="stat-card bg-white rounded-xl border border-slate-200 p-5 shadow-sm">
    <div class="flex items-center justify-between mb-3">
        <div class="w-8 h-8 bg-orange-50 rounded-lg flex items-center justify-center">
            <i data-lucide="clipboard-list" class="w-4 h-4 text-orange-500"></i>
        </div>
    </div>
    <p class="text-2xl font-bold text-slate-900 tabular-nums"><%= stats.pesananBaru %></p>
    <p class="text-[11px] text-slate-400 mt-0.5">Pesanan Baru</p>
  </div>

  <div class="stat-card bg-white rounded-xl border border-slate-200 p-5 shadow-sm">
    <div class="flex items-center justify-between mb-3">
        <div class="w-8 h-8 bg-violet-50 rounded-lg flex items-center justify-center">
            <i data-lucide="boxes" class="w-4 h-4 text-violet-500"></i>
        </div>
    </div>
    <p class="text-2xl font-bold text-slate-900 tabular-nums"><%= stats.totalProduk %></p>
    <p class="text-[11px] text-slate-400 mt-0.5">Total SKU Terdaftar</p>
  </div>

  <div class="stat-card bg-white rounded-xl border border-slate-200 p-5 shadow-sm">
    <div class="flex items-center justify-between mb-3">
        <div class="w-8 h-8 bg-red-50 rounded-lg flex items-center justify-center">
            <i data-lucide="alert-triangle" class="w-4 h-4 text-red-500"></i>
        </div>
    </div>
    <p class="text-2xl font-bold text-brand-red tabular-nums"><%= stats.stokMenipis %></p>
    <p class="text-[11px] text-slate-400 mt-0.5">Stok Menipis</p>
  </div>
</div>

<div class="bg-white p-8 rounded-xl border border-slate-100 shadow-sm relative overflow-hidden">
    <div class="relative z-10">
        <h2 class="text-xl font-bold text-brand-dark mb-2">Halo, <%= user.username %>!</h2>
        <p class="text-sm text-slate-500 max-w-lg">
            Panel ini adalah pusat kendali untuk mengelola inventaris sparepart, memantau pesanan customer, dan memverifikasi pembayaran. Silakan pilih menu di samping untuk mulai bekerja.
        </p>
    </div>
    <div class="absolute -bottom-8 -right-8 opacity-5 text-brand-dark">
        <i data-lucide="cog" class="w-48 h-48 rotate-12"></i>
    </div>
</div>

<%- include('partials/footer') %>
