<%- include('partials/header') %>
<%- include('partials/sidebar') %>

<div class="mb-6">
  <h1 class="text-xl font-bold text-brand-dark tracking-tight">Selamat Datang, Admin</h1>
  <p class="text-xs text-slate-400 mt-0.5">Ringkasan operasional hari ini.</p>
</div>

<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
  <div class="stat-card bg-white rounded-xl border border-slate-200 p-5 shadow-sm">
    <div class="flex items-center justify-between mb-3">
        <div class="w-8 h-8 bg-blue-50 rounded-lg flex items-center justify-center">
            <i data-lucide="trending-up" class="w-4 h-4 text-blue-500"></i>
        </div>
    </div>
    <p class="text-2xl font-bold text-slate-900 tabular-nums">Rp<%= stats.totalPenjualan.toLocaleString('id-ID') %></p>
    <p class="text-[11px] text-slate-400 mt-0.5">Total Penjualan</p>
  </div>
  
  <div class="stat-card bg-white rounded-xl border border-slate-200 p-5 shadow-sm">
    <div class="flex items-center justify-between mb-3">
        <div class="w-8 h-8 bg-orange-50 rounded-lg flex items-center justify-center">
            <i data-lucide="clipboard-list" class="w-4 h-4 text-orange-500"></i>
        </div>
    </div>
    <p class="text-2xl font-bold text-slate-900 tabular-nums"><%= stats.pesananBaru %></p>
    <p class="text-[11px] text-slate-400 mt-0.5">Pesanan Baru</p>
  </div>

  <div class="stat-card bg-white rounded-xl border border-slate-200 p-5 shadow-sm">
    <div class="flex items-center justify-between mb-3">
        <div class="w-8 h-8 bg-violet-50 rounded-lg flex items-center justify-center">
            <i data-lucide="boxes" class="w-4 h-4 text-violet-500"></i>
        </div>
    </div>
    <p class="text-2xl font-bold text-slate-900 tabular-nums"><%= stats.totalProduk %></p>
    <p class="text-[11px] text-slate-400 mt-0.5">Total SKU Terdaftar</p>
  </div>

  <div class="stat-card bg-white rounded-xl border border-slate-200 p-5 shadow-sm">
    <div class="flex items-center justify-between mb-3">
        <div class="w-8 h-8 bg-red-50 rounded-lg flex items-center justify-center">
            <i data-lucide="alert-triangle" class="w-4 h-4 text-red-500"></i>
        </div>
    </div>
    <p class="text-2xl font-bold text-brand-red tabular-nums"><%= stats.stokMenipis %></p>
    <p class="text-[11px] text-slate-400 mt-0.5">Stok Menipis</p>
  </div>
</div>

<!-- Grid Section: 2 Row, 2 Column on Large Screens -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
  
  <!-- Section 1: Pesanan Terakhir -->
  <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
    <div class="p-5 border-b border-slate-100 flex items-center justify-between">
      <h3 class="font-bold text-slate-800">Pesanan Terakhir</h3>
      <a href="/admin/pesanan" class="text-xs font-semibold text-brand-red hover:underline">Lihat Semua</a>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse">
        <thead class="bg-slate-50 text-[10px] uppercase tracking-wider text-slate-500 font-semibold">
          <tr>
            <th class="px-5 py-3">ID Pesanan</th>
            <th class="px-5 py-3">Customer</th>
            <th class="px-5 py-3">Total</th>
            <th class="px-5 py-3 text-right">Status</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100 text-sm">
          <% if (recentOrders.length > 0) { %>
            <% recentOrders.forEach(order => { %>
              <tr class="hover:bg-slate-50 transition-colors">
                <td class="px-5 py-4 font-medium text-slate-700">#<%= order.id_pembelian.substring(0, 8) %></td>
                <td class="px-5 py-4 text-slate-600"><%= order.username %></td>
                <td class="px-5 py-4 text-slate-900 font-semibold text-xs">Rp<%= order.total_bayar.toLocaleString('id-ID') %></td>
                <td class="px-5 py-4 text-right">
                  <% 
                    let statusClass = 'bg-slate-100 text-slate-600';
                    if (order.status === 'menunggu_verifikasi') statusClass = 'bg-orange-50 text-orange-600';
                    if (order.status === 'diproses') statusClass = 'bg-blue-50 text-blue-600';
                    if (order.status === 'selesai') statusClass = 'bg-green-50 text-green-600';
                  %>
                  <span class="px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-tight <%= statusClass %>">
                    <%= order.status %>
                  </span>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="4" class="px-5 py-8 text-center text-slate-400 italic text-xs">Belum ada pesanan masuk</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Section 2: Pertumbuhan Penjualan -->
  <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-5">
    <div class="flex items-center justify-between mb-6">
      <h3 class="font-bold text-slate-800">Pertumbuhan Penjualan</h3>
      <div class="px-3 py-1 bg-slate-100 rounded text-[10px] font-bold text-slate-500">7 HARI TERAKHIR</div>
    </div>
    <div class="h-[240px] w-full">
      <canvas id="salesChart"></canvas>
    </div>
  </div>

  <!-- Section 3: Produk Terpopuler -->
  <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-5">
    <h3 class="font-bold text-slate-800 mb-5">Produk Terpopuler</h3>
    <div class="space-y-4">
      <% if (topProducts.length > 0) { %>
        <% topProducts.forEach(prod => { %>
          <div class="flex items-center gap-4 group">
            <div class="w-12 h-12 rounded-lg bg-slate-50 border border-slate-100 overflow-hidden shrink-0">
              <img src="<%= prod.gambar || '/assets/busi.jpg' %>" alt="" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300">
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-semibold text-slate-800 truncate"><%= prod.nama_produk %></p>
              <p class="text-xs text-slate-400"><%= prod.terjual %> item terjual</p>
            </div>
            <div class="text-xs font-bold text-blue-600 bg-blue-50 px-2 py-1 rounded">Top</div>
          </div>
        <% }) %>
      <% } else { %>
        <p class="text-center py-10 text-slate-400 italic text-xs">Belum ada data penjualan produk</p>
      <% } %>
    </div>
  </div>

  <!-- Section 4: Stok Menipis Details -->
  <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-5">
    <h3 class="font-bold text-slate-800 mb-5">Peringatan Stok Rendah</h3>
    <div class="space-y-4">
      <% if (lowStockProducts.length > 0) { %>
        <% lowStockProducts.forEach(prod => { %>
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-lg bg-slate-50 border border-slate-100 overflow-hidden shrink-0">
              <img src="<%= prod.gambar || '/assets/busi.jpg' %>" alt="" class="w-full h-full object-cover grayscale">
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-semibold text-slate-800 truncate"><%= prod.nama_produk %></p>
              <div class="flex items-center gap-2 mt-0.5">
                <div class="flex-1 h-1.5 bg-slate-100 rounded-full overflow-hidden">
                  <div class="h-full bg-red-500 rounded-full" style="width: <%= (prod.stok / 10) * 100 %>%"></div>
                </div>
                <span class="text-[11px] font-bold text-red-600 shrink-0"><%= prod.stok %> left</span>
              </div>
            </div>
            <a href="/admin/produk" class="p-2 text-slate-400 hover:text-brand-red transition-colors">
              <i data-lucide="external-link" class="w-4 h-4"></i>
            </a>
          </div>
        <% }) %>
      <% } else { %>
        <p class="text-center py-10 text-slate-400 italic text-xs">Semua stok produk aman</p>
      <% } %>
    </div>
  </div>

</div>

<!-- Chart Script -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  const ctx = document.getElementById('salesChart').getContext('2d');
  const salesData = <%- JSON.stringify(salesGrowth) %>;
  
  const labels = salesData.map(d => {
    const date = new Date(d.tgl);
    return date.toLocaleDateString('id-ID', { day: '2-digit', month: 'short' });
  });
  const values = salesData.map(d => d.total);

  new Chart(ctx, {
    type: 'line',
    data: {
      labels: labels,
      datasets: [{
        label: 'Pendapatan (Rp)',
        data: values,
        borderColor: '#EF4444',
        backgroundColor: 'rgba(239, 68, 68, 0.05)',
        borderWidth: 3,
        fill: true,
        tension: 0.4,
        pointBackgroundColor: '#EF4444',
        pointBorderColor: '#fff',
        pointBorderWidth: 2,
        pointRadius: 4,
        pointHoverRadius: 6
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          backgroundColor: '#1E293B',
          padding: 12,
          titleFont: { size: 13, weight: 'bold' },
          bodyFont: { size: 12 },
          displayColors: false,
          callbacks: {
            label: (context) => 'Rp' + context.parsed.y.toLocaleString('id-ID')
          }
        }
      },
      scales: {
        y: {
          beginAtZero: true,
          grid: { borderDash: [5, 5], color: '#f1f5f9' },
          ticks: {
            font: { size: 10 },
            callback: (value) => 'Rp' + (value / 1000) + 'k'
          }
        },
        x: {
          grid: { display: false },
          ticks: { font: { size: 10 } }
        }
      }
    }
  });
</script>

<div class="bg-white p-8 rounded-xl border border-slate-100 shadow-sm relative overflow-hidden">
    <div class="relative z-10">
        <h2 class="text-xl font-bold text-brand-dark mb-2">Halo, <%= user.username %>!</h2>
        <p class="text-sm text-slate-500 max-w-lg">
            Panel ini adalah pusat kendali untuk mengelola inventaris sparepart, memantau pesanan customer, dan memverifikasi pembayaran. Silakan pilih menu di samping untuk mulai bekerja.
        </p>
    </div>
    <div class="absolute -bottom-8 -right-8 opacity-5 text-brand-dark">
        <i data-lucide="cog" class="w-48 h-48 rotate-12"></i>
    </div>
</div>

<%- include('partials/footer') %>
