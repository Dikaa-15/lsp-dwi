<%- include('partials/header') %>
<%- include('partials/sidebar') %>

<div class="flex items-center justify-between mb-8">
    <div>
        <h1 class="text-lg font-bold text-brand-dark tracking-tight">Verifikasi Pesanan</h1>
        <p class="text-xs text-slate-400 mt-1">Kelola dan verifikasi pembayaran dari customer.</p>
    </div>
</div>

<!-- Table -->
<div class="bg-white rounded-md border border-slate-200 shadow-sm overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="border-b border-slate-100 bg-slate-50/50">
                    <th class="px-5 py-3 text-[10px] font-semibold text-slate-400 uppercase tracking-wider">ID Pesanan</th>
                    <th class="px-5 py-3 text-[10px] font-semibold text-slate-400 uppercase tracking-wider">Customer</th>
                    <th class="px-5 py-3 text-[10px] font-semibold text-slate-400 uppercase tracking-wider">Total</th>
                    <th class="px-5 py-3 text-[10px] font-semibold text-slate-400 uppercase tracking-wider">Status</th>
                    <th class="px-5 py-3 text-[10px] font-semibold text-slate-400 uppercase tracking-wider text-right">Aksi</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-50">
                <% orders.forEach(o => { %>
                    <tr class="list-row hover:bg-slate-50/50">
                        <td class="px-5 py-4 text-[13px] font-mono font-semibold text-brand-dark"><%= o.id_pembelian %></td>
                        <td class="px-5 py-4">
                            <p class="text-[13px] font-medium text-brand-dark"><%= o.username %></p>
                            <p class="text-[10px] text-slate-400"><%= o.whatsapp %></p>
                        </td>
                        <td class="px-5 py-4 text-[13px] font-bold text-brand-dark">Rp<%= o.total_bayar.toLocaleString('id-ID') %></td>
                        <td class="px-5 py-4">
                            <span class="px-2 py-1 rounded text-[10px] font-bold uppercase 
                                <%= o.status === 'menunggu_verifikasi' ? 'bg-orange-100 text-orange-600' : 
                                   o.status === 'diproses' ? 'bg-blue-100 text-blue-600' : 
                                   o.status === 'dikirim' ? 'bg-green-100 text-green-600' : 'bg-slate-100 text-slate-600' %>">
                                <%= o.status.replace('_', ' ') %>
                            </span>
                        </td>
                        <td class="px-5 py-4 text-right">
                            <button onclick="viewDetail('<%= o.id_pembelian %>', '<%= o.bukti_transfer %>', '<%= o.status %>', '<%= o.metode_pembayaran || 'bca' %>', '<%= o.metode_pengiriman %>')" class="text-xs font-semibold text-blue-500 hover:underline">Periksa</button>
                        </td>
                    </tr>
                <% }) %>
                <% if (orders.length === 0) { %>
                    <tr>
                        <td colspan="5" class="px-5 py-12 text-center text-slate-400 text-xs">Belum ada pesanan</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<!-- Detail Modal -->
<div id="order-modal" class="modal-hidden fixed inset-0 z-[150] flex items-center justify-center p-4">
    <div class="modal-overlay absolute inset-0 bg-black/30" onclick="closeModal()"></div>
    <div class="modal-panel relative bg-white rounded-lg shadow-xl w-full max-w-lg overflow-hidden">
        <div class="flex items-center justify-between px-5 py-4 border-b border-slate-100">
            <h3 class="text-sm font-semibold text-brand-dark">Verifikasi Pembayaran</h3>
            <button onclick="closeModal()" class="text-slate-400 hover:text-slate-600"><i data-lucide="x" class="w-4 h-4"></i></button>
        </div>
        <div class="p-6 space-y-6">
            <!-- Proof Image -->
            <div>
                <p class="text-[10px] font-bold text-slate-400 uppercase mb-2">Bukti Transfer</p>
                <div class="bg-slate-50 rounded-md border border-slate-200 p-2">
                    <img id="modal-proof" src="" class="hidden w-full h-auto max-h-[300px] object-contain bg-white rounded">
                    <div id="modal-proof-empty" class="w-full min-h-[160px] flex items-center justify-center bg-white rounded text-slate-400 text-xs font-medium">
                        Bukti transfer tidak tersedia
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div class="bg-slate-50 rounded-md border border-slate-200 px-4 py-3">
                    <p class="text-[10px] font-bold text-slate-400 uppercase mb-1">Metode Pembayaran</p>
                    <p id="modal-payment" class="text-sm font-semibold text-brand-dark">-</p>
                </div>
                <div class="bg-slate-50 rounded-md border border-slate-200 px-4 py-3">
                    <p class="text-[10px] font-bold text-slate-400 uppercase mb-1">Metode Pengiriman</p>
                    <p id="modal-shipping" class="text-sm font-semibold text-brand-dark uppercase">-</p>
                </div>
            </div>

            <!-- Items -->
            <div id="modal-items" class="space-y-2">
                <!-- Injected -->
            </div>

            <!-- Actions -->
            <div id="modal-actions" class="flex flex-col gap-3">
                <!-- Injected -->
            </div>
        </div>
    </div>
</div>

<script>
    function viewDetail(id, proof, status, paymentMethod) {
        const proofImg = document.getElementById('modal-proof');
        const proofEmpty = document.getElementById('modal-proof-empty');
        proofImg.onerror = () => {
            proofImg.classList.add('hidden');
            proofEmpty.classList.remove('hidden');
        };
        proofImg.onload = () => {
            proofImg.classList.remove('hidden');
            proofEmpty.classList.add('hidden');
        };
        if (proof) {
            proofEmpty.classList.add('hidden');
            proofImg.classList.add('hidden');
            proofImg.src = proof;
        } else {
            proofImg.src = '';
            proofImg.classList.add('hidden');
            proofEmpty.classList.remove('hidden');
        }
        const actionDiv = document.getElementById('modal-actions');
        actionDiv.innerHTML = '';
        document.getElementById('modal-payment').textContent = paymentMethod ? paymentMethod.toUpperCase() : '-';
        document.getElementById('modal-shipping').textContent = arguments[4] || '-';

        if (status === 'menunggu_verifikasi') {
            actionDiv.innerHTML = `
                <div class="flex gap-3">
                    <button onclick="updateStatus('${id}', 'diproses')" class="flex-1 bg-green-500 text-white py-2 rounded-md text-sm font-bold">Verifikasi & Proses</button>
                    <button onclick="showRejectionInput()" class="flex-1 border border-red-500 text-red-500 py-2 rounded-md text-sm font-bold">Tolak Pesanan</button>
                </div>
                <div id="rejection-container" class="hidden space-y-2 mt-2 pt-2 border-t">
                    <p class="text-[10px] font-bold text-red-500 uppercase">Alasan Penolakan</p>
                    <textarea id="alasan-input" placeholder="Contoh: Bukti transfer tidak valid / tidak terbaca" class="w-full px-3 py-2 border rounded-md text-sm min-h-[80px]"></textarea>
                    <button onclick="updateStatus('${id}', 'dibatalkan')" class="w-full bg-red-500 text-white py-2 rounded-md text-sm font-bold">Konfirmasi Tolak</button>
                </div>
            `;
        } else if (status === 'diproses') {
            actionDiv.innerHTML = `
                <div class="w-full space-y-3">
                    <input id="resi-input" type="text" placeholder="Masukkan Nomor Resi" class="w-full px-3 py-2 border rounded-md text-sm">
                    <button onclick="updateStatus('${id}', 'dikirim')" class="w-full bg-blue-500 text-white py-2 rounded-md text-sm font-bold">Kirim Pesanan</button>
                </div>
            `;
        } else if (status === 'dikirim') {
            actionDiv.innerHTML = `
                <div class="w-full rounded-md border border-slate-200 bg-slate-50 px-4 py-3 text-xs text-slate-500">
                    Pesanan sudah dikirim. Menunggu customer menandai selesai.
                </div>
            `;
        }

        // Fetch items
        fetch(`/admin/pesanan/detail/${id}`)
            .then(res => res.json())
            .then(items => {
                const itemsDiv = document.getElementById('modal-items');
                itemsDiv.innerHTML = '<p class="text-[10px] font-bold text-slate-400 uppercase mb-2">Item Pesanan</p>';
                items.forEach(item => {
                    itemsDiv.innerHTML += `
                        <div class="flex items-center justify-between text-xs py-1 border-b border-slate-100 last:border-0">
                            <span>${item.nama_produk} (x${item.jumlah})</span>
                            <span class="font-bold">Rp${(item.jumlah * item.harga_saat_beli).toLocaleString('id-ID')}</span>
                        </div>
                    `;
                });
            });

        document.getElementById('order-modal').classList.remove('modal-hidden');
        lucide.createIcons();
    }

    function showRejectionInput() {
        document.getElementById('rejection-container').classList.remove('hidden');
    }

    function closeModal() {
        document.getElementById('order-modal').classList.add('modal-hidden');
    }

    function updateStatus(id, status) {
        const resi = document.getElementById('resi-input')?.value;
        const alasan = document.getElementById('alasan-input')?.value;

        if (status === 'dibatalkan' && !alasan?.trim()) {
            alert('Silakan masukkan alasan penolakan.');
            return;
        }

        fetch('/admin/pesanan/update-status', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ 
                id_pembelian: id, 
                status, 
                no_resi: resi,
                alasan_penolakan: alasan 
            })
        }).then(res => res.json()).then(data => {
            if (data.success) location.reload();
            else alert(data.message);
        });
    }
</script>

<%- include('partials/footer') %>
