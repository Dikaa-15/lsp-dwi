<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Form Tambah -->
    <div class="bg-white p-6 rounded-xl border border-slate-100 shadow-sm h-fit">
        <h2 class="text-sm font-bold text-brand-dark uppercase tracking-wider mb-4">Tambah Kategori</h2>
        <form action="/admin/kategori/store" method="POST" class="space-y-4">
            <div>
                <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Nama Kategori</label>
                <input type="text" name="nama_kategori" required placeholder="Contoh: Mesin, Body, dll" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:outline-none focus:border-brand-red transition-all">
            </div>
            <button type="submit" class="w-full py-2.5 bg-brand-red hover:bg-brand-red-hover text-white text-xs font-bold rounded-lg transition-colors shadow-sm">
                Simpan Kategori
            </button>
        </form>
    </div>

    <!-- Tabel Data -->
    <div class="lg:col-span-2 bg-white rounded-xl border border-slate-100 shadow-sm overflow-hidden">
        <div class="p-6 border-b border-slate-50 flex items-center justify-between">
            <h2 class="text-sm font-bold text-brand-dark uppercase tracking-wider">Daftar Kategori</h2>
            <span class="text-xs text-slate-400 font-medium"><%= categories.length %> Total</span>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50/50">
                        <th class="px-6 py-3 text-[10px] font-bold text-slate-400 uppercase tracking-widest border-b border-slate-100">No.</th>
                        <th class="px-6 py-3 text-[10px] font-bold text-slate-400 uppercase tracking-widest border-b border-slate-100">Nama Kategori</th>
                        <th class="px-6 py-3 text-[10px] font-bold text-slate-400 uppercase tracking-widest border-b border-slate-100 text-right">Aksi</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    <% if (categories && categories.length > 0) { %>
                        <% categories.forEach((item, index) => { %>
                            <tr class="hover:bg-slate-50/50 transition-colors">
                                <td class="px-6 py-4 text-sm text-slate-500"><%= index + 1 %></td>
                                <td class="px-6 py-4 text-sm font-semibold text-brand-dark"><%= item.nama_kategori %></td>
                                <td class="px-6 py-4 text-right">
                                    <div class="flex items-center justify-end gap-2">
                                        <button onclick="editKategori('<%= item.id %>', '<%= item.nama_kategori %>')" class="p-2 text-slate-400 hover:text-blue-500 hover:bg-blue-50 rounded-md transition-all" title="Edit">
                                            <i data-lucide="edit-3" class="w-4 h-4"></i>
                                        </button>
                                        <a href="/admin/kategori/delete/<%= item.id %>" onclick="return confirm('Hapus kategori ini?')" class="p-2 text-slate-400 hover:text-red-500 hover:bg-red-50 rounded-md transition-all" title="Hapus">
                                            <i data-lucide="trash-2" class="w-4 h-4"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="3" class="px-6 py-12 text-center text-sm text-slate-400">Belum ada data kategori.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal Edit (Simple implementation) -->
<div id="modal-edit" class="fixed inset-0 z-[100] hidden">
    <div class="absolute inset-0 bg-brand-dark/40 backdrop-blur-sm" onclick="closeModal()"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-md px-6">
        <div class="bg-white rounded-xl shadow-xl overflow-hidden">
            <div class="p-6 border-b border-slate-50 flex items-center justify-between">
                <h3 class="font-bold text-brand-dark">Edit Kategori</h3>
                <button onclick="closeModal()" class="text-slate-400 hover:text-slate-600"><i data-lucide="x" class="w-5 h-5"></i></button>
            </div>
            <form id="form-edit" method="POST" class="p-6 space-y-4">
                <div>
                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Nama Kategori</label>
                    <input type="text" name="nama_kategori" id="edit-nama" required class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:outline-none focus:border-brand-red transition-all">
                </div>
                <button type="submit" class="w-full py-2.5 bg-brand-red hover:bg-brand-red-hover text-white text-xs font-bold rounded-lg transition-colors">
                    Update Kategori
                </button>
            </form>
        </div>
    </div>
</div>

<script>
    function editKategori(id, nama) {
        const modal = document.getElementById('modal-edit');
        const form = document.getElementById('form-edit');
        const input = document.getElementById('edit-nama');
        
        form.action = `/admin/kategori/update/${id}`;
        input.value = nama;
        
        modal.classList.remove('hidden');
        lucide.createIcons();
    }

    function closeModal() {
        document.getElementById('modal-edit').classList.add('hidden');
    }
</script>

<%- include('../partials/footer') %>
