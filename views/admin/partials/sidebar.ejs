<!-- Sidebar -->
<aside id="sidebar" class="sidebar-panel fixed lg:sticky top-0 left-0 z-[100] w-56 h-screen bg-brand-dark flex flex-col -translate-x-full lg:translate-x-0 dark-scroll overflow-y-auto">
    <div class="flex items-center gap-2.5 px-5 h-14 border-b border-white/[0.06] shrink-0">
        <div class="w-7 h-7 bg-brand-red rounded-lg flex items-center justify-center">
            <i data-lucide="cog" class="w-3.5 h-3.5 text-white"></i>
        </div>
        <div>
            <span class="text-sm font-semibold text-white tracking-tight block leading-none">AutoPart</span>
            <span class="text-[9px] text-slate-500 font-medium tracking-wider uppercase">Admin</span>
        </div>
        <button onclick="closeSidebar()" class="lg:hidden ml-auto w-7 h-7 flex items-center justify-center rounded-md text-slate-500 hover:text-slate-300">
            <i data-lucide="x" class="w-4 h-4"></i>
        </button>
    </div>

    <nav class="flex-1 py-4 px-3">
        <p class="px-2.5 mb-2 text-[9px] font-semibold text-slate-600 uppercase tracking-widest">Menu</p>
        
        <a href="/admin/dashboard" class="nav-link flex items-center gap-3 px-2.5 py-2.5 rounded-lg text-sm text-slate-400 mb-0.5 <%= title.includes('Dashboard') ? 'active' : '' %>">
            <i data-lucide="layout-dashboard" class="w-[18px] h-[18px] nav-icon shrink-0"></i> Dashboard
        </a>

        <a href="/admin/produk" class="nav-link flex items-center gap-3 px-2.5 py-2.5 rounded-lg text-sm text-slate-400 mb-0.5 <%= title.includes('Produk') ? 'active' : '' %>">
            <i data-lucide="package" class="w-[18px] h-[18px] nav-icon shrink-0"></i> Produk
        </a>

        <a href="/admin/kategori-brand" class="nav-link flex items-center gap-3 px-2.5 py-2.5 rounded-lg text-sm text-slate-400 mb-0.5 <%= title.includes('Kategori') ? 'active' : '' %>">
            <i data-lucide="tags" class="w-[18px] h-[18px] nav-icon shrink-0"></i> Brand & Kategori
        </a>

        <a href="/admin/pesanan" class="nav-link flex items-center gap-3 px-2.5 py-2.5 rounded-lg text-sm text-slate-400 mb-0.5 <%= title.includes('Pesanan') ? 'active' : '' %>">
            <i data-lucide="clipboard-check" class="w-[18px] h-[18px] nav-icon shrink-0"></i> 
            <span class="flex-1">Pesanan</span>
            <% if (pendingOrdersCount > 0) { %>
                <span class="bg-brand-red text-white text-[10px] font-bold px-2 py-0.5 rounded-full"><%= pendingOrdersCount %></span>
            <% } %>
        </a>

        <p class="px-2.5 mt-6 mb-2 text-[9px] font-semibold text-slate-600 uppercase tracking-widest">Sistem</p>
        
        <a href="/auth/logout" class="nav-link flex items-center gap-3 px-2.5 py-2.5 rounded-lg text-sm text-slate-500 hover:text-red-400">
            <i data-lucide="log-out" class="w-[18px] h-[18px] shrink-0"></i> Logout
        </a>
    </nav>
    
    <div class="px-5 py-3 border-t border-white/[0.06] shrink-0">
        <p class="text-[9px] text-slate-700 text-center">AutoPart Center v1.0</p>
    </div>
</aside>

<!-- Top Bar -->
<div class="flex-1 min-w-0 flex flex-col">
    <header class="sticky top-0 z-50 bg-white/95 backdrop-blur-md border-b border-slate-100 h-14 flex items-center px-4 sm:px-6 shrink-0">
        <button onclick="openSidebar()" class="lg:hidden w-9 h-9 flex items-center justify-center rounded-lg hover:bg-slate-50 text-slate-500 mr-3">
            <i data-lucide="menu" class="w-5 h-5"></i>
        </button>
        <div class="flex items-center gap-2">
            <h2 class="text-sm font-semibold text-brand-dark"><%= title %></h2>
        </div>
        <div class="ml-auto flex items-center gap-3">
            <div class="text-right hidden sm:block">
                <p class="text-xs font-semibold text-brand-dark"><%= user.username %></p>
                <p class="text-[10px] text-slate-400 uppercase tracking-wider"><%= user.role %></p>
            </div>
            <div class="w-8 h-8 bg-slate-100 rounded-full flex items-center justify-center text-brand-dark font-bold text-xs border border-slate-200">
                <%= user.username.charAt(0).toUpperCase() %>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="flex-1 overflow-y-auto p-4 sm:p-6 lg:p-8">
