<% const resolvedWrapperClass = typeof wrapperClass !== 'undefined' ? wrapperClass : ''; %>
<% const resolvedLabel = typeof label !== 'undefined' ? label : 'Kembali'; %>
<% const resolvedFallback = typeof fallback !== 'undefined' ? fallback : '/'; %>
<div class="<%= resolvedWrapperClass %>">
  <button
    type="button"
    onclick="window.history.length > 1 ? window.history.back() : window.location.href = '<%= resolvedFallback %>'"
    class="inline-flex items-center gap-1.5 text-xs font-semibold text-slate-400 hover:text-brand-red transition-colors border border-slate-200 px-4 py-2 rounded-full hover:border-brand-red"
  >
    <i data-lucide="arrow-left" class="w-3 h-3"></i>
    <%= resolvedLabel %>
  </button>
</div>
